# Required
OPENAI_API_KEY=sk-...

# HeyGen — the Photo Avatar / AI Avatar generation
HEYGEN_API_KEY=...

# Skip real HeyGen rendering. Reuses a cached .data/videos/<id>.mp4 chosen
# deterministically from the paper id. Use during Hyperframes iteration.
MOCK_HEYGEN=

# Optional sponsor keys (we fall back to OpenAI if missing)
FAL_KEY=
ELEVENLABS_API_KEY=
ASSEMBLYAI_API_KEY=

# PostHog — required for NorthStar mode (data source for the videos).
#  HOST                US cloud: https://us.i.posthog.com   ·   EU: https://eu.i.posthog.com
#  PROJECT_API_KEY     starts with `phc_` — used for INGESTING events (seeding sample data)
#  PERSONAL_API_KEY    starts with `phx_` — used for READING insights/queries
#  PROJECT_ID          numeric ID, visible in the URL of any project page
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_API_KEY=phc_...
POSTHOG_PERSONAL_API_KEY=phx_...
POSTHOG_PROJECT_ID=
