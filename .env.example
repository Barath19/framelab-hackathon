# Required
OPENAI_API_KEY=sk-...

# HeyGen — the Photo Avatar / AI Avatar generation
HEYGEN_API_KEY=...

# Skip real HeyGen rendering. Reuses a cached .data/videos/<id>.mp4 chosen
# deterministically from the paper id. Use during Hyperframes iteration.
MOCK_HEYGEN=

# Optional sponsor keys (we fall back to OpenAI if missing)
FAL_KEY=
ELEVENLABS_API_KEY=
ASSEMBLYAI_API_KEY=
